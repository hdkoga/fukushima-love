---
import Base from '../layouts/Base.astro';
import { getEnrichedEvents, formatDate } from '../lib/data';

const events = await getEnrichedEvents();

// 年ごとにグループ化
const byYear = new Map<number, typeof events>();
for (const e of events) {
  const m = e.date.match(/(\d{4})/);
  if (!m) continue;
  const year = Number(m[1]);
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(e);
}

// 年を昇順ソート
const years = [...byYear.keys()].sort((a, b) => a - b);

// 節目回（10の倍数）
const MILESTONE_MOD = 10;
const isMilestone = (kai: number) => kai % MILESTONE_MOD === 0;
---

<Base title="タイムライン | 福島LOVE会">
  <main class="container" style="padding-top: 2rem; padding-bottom: 4rem;">
    <h1>タイムライン</h1>
    <p style="color: var(--color-sub); margin-bottom: 2.5rem;">
      {years[0]}年から{years[years.length - 1]}年まで、{events.length}回の軌跡。
    </p>

    <div class="tl-wrap">
      {years.map((year) => {
        const yearEvents = byYear.get(year)!;
        return (
          <div class="tl-year-block">
            <div class="tl-year-label">
              <span class="tl-year-num">{year}</span>
              <span class="tl-year-count">{yearEvents.length}回</span>
            </div>
            <div class="tl-events">
              {yearEvents.map((e) => (
                <a
                  href={`/events/${e.kai}/`}
                  class={`tl-item${isMilestone(e.kai) ? ' tl-milestone' : ''}`}
                >
                  {e.photos.length > 0 && (
                    <img class="tl-thumb" src={e.photos[0]} alt={`第${e.kai}回`} loading="lazy" />
                  )}
                  <div class="tl-info">
                    <div class="tl-kai">
                      {isMilestone(e.kai) && <span class="tl-milestone-badge">★</span>}
                      第{e.kai}回
                    </div>
                    <div class="tl-store">{e.storeName}</div>
                    {e.notes && <div class="tl-notes">{e.notes}</div>}
                    <div class="tl-date">{formatDate(e.date)}</div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </main>
</Base>

<style>
.tl-wrap {
  position: relative;
  padding-left: 5rem;
}

/* 縦線 */
.tl-wrap::before {
  content: '';
  position: absolute;
  left: 3.5rem;
  top: 0;
  bottom: 0;
  width: 2px;
  background: var(--color-border);
}

/* 年ブロック */
.tl-year-block {
  position: relative;
  margin-bottom: 2.5rem;
}

/* 年ラベル */
.tl-year-label {
  position: absolute;
  left: -5rem;
  top: 0;
  width: 4.2rem;
  text-align: right;
  padding-right: 0.75rem;
}

.tl-year-num {
  display: block;
  font-size: 1.1rem;
  font-weight: 900;
  color: var(--color-ink);
  line-height: 1.2;
}

.tl-year-count {
  display: block;
  font-size: 0.72rem;
  color: var(--color-muted);
  margin-top: 0.1rem;
}

/* 年ブロック先頭の丸 */
.tl-year-block::before {
  content: '';
  position: absolute;
  left: -1.65rem;
  top: 0.35rem;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--color-accent);
  border: 2px solid #fff;
  box-shadow: 0 0 0 2px var(--color-accent);
}

/* イベント一覧 */
.tl-events {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

/* 各イベント行 */
.tl-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.6rem 0.75rem;
  border-radius: var(--radius);
  border: 1px solid var(--color-border);
  background: var(--color-card);
  text-decoration: none;
  color: inherit;
  transition: box-shadow var(--transition), background var(--transition);
}

.tl-item:hover {
  box-shadow: var(--shadow-hover);
  background: #fdf5f4;
}

/* 節目回 */
.tl-item.tl-milestone {
  border-color: var(--color-accent);
  background: rgba(230, 51, 41, 0.04);
}

.tl-item.tl-milestone:hover {
  background: rgba(230, 51, 41, 0.08);
}

/* サムネイル */
.tl-thumb {
  width: 52px;
  height: 52px;
  object-fit: cover;
  border-radius: 6px;
  flex-shrink: 0;
}

/* 情報 */
.tl-info {
  flex: 1;
  min-width: 0;
}

.tl-kai {
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--color-muted);
  margin-bottom: 0.1rem;
}

.tl-milestone-badge {
  color: var(--color-accent);
  margin-right: 0.2em;
}

.tl-store {
  font-weight: 700;
  font-size: 0.95rem;
  color: var(--color-ink);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tl-notes {
  font-size: 0.8rem;
  color: var(--color-sub);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-top: 0.1rem;
}

.tl-date {
  font-size: 0.75rem;
  color: var(--color-muted);
  margin-top: 0.15rem;
}

/* モバイル */
@media (max-width: 480px) {
  .tl-wrap {
    padding-left: 3.5rem;
  }
  .tl-wrap::before {
    left: 2.5rem;
  }
  .tl-year-label {
    left: -3.5rem;
    width: 3rem;
    padding-right: 0.5rem;
  }
  .tl-year-num {
    font-size: 0.85rem;
  }
  .tl-year-block::before {
    left: -1.15rem;
  }
  .tl-thumb {
    width: 40px;
    height: 40px;
  }
}
</style>
