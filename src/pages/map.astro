---
import Base from '../layouts/Base.astro';
import MapListView from '../components/MapListView.astro';
import { getEnrichedEvents } from '../lib/data';

const events = await getEnrichedEvents();
---

<Base title="マップ | 福島LOVE会">
  <main class="container" style="padding-top: 2rem;">
    <h1>全店マップ</h1>
    <p style="color: var(--color-sub); font-size: 0.9rem; margin-bottom: 1rem;">
      これまで訪れた福島縁の店を地図で俯瞰。ピンをクリックすると各回の詳細・写真ページへ。
    </p>
    <MapListView events={events} height="calc(100vh - 240px)" />
  </main>
</Base>
